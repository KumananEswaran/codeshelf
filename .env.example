# Neon PostgreSQL
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/codeshelf?sslmode=require"

# NextAuth
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend (email verification & password reset)
# Get your API key from https://resend.com
RESEND_API_KEY=

# App URL (used for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email verification (set to "true" to require email verification on register)
REQUIRE_EMAIL_VERIFICATION=false
